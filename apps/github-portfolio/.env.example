# GitHub Portfolio - Environment Configuration
# Copy this file to .env.local and fill in the values

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
# Controls the rate limiting for the API route (requests per IP per window)

# Rate limit window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Maximum requests per IP within the window (default: 10)
RATE_LIMIT_MAX_REQUESTS=10

# =============================================================================
# GitHub API (Optional)
# =============================================================================
# For higher rate limits, you can add a GitHub personal access token.
# This is optional - the app works without it using unauthenticated requests.
# Token only needs public_repo scope for public repositories.

# GITHUB_API_TOKEN=your_github_token_here

# =============================================================================
# Next.js Configuration
# =============================================================================
# These are typically not needed for local development

# NODE_ENV=development
# NEXT_PUBLIC_APP_URL=http://localhost:3000
